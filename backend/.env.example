ENV=development
DATABASE_URL=postgresql://user:password@host:port/dbname
# Optional: transaction-mode pooler URL (same credentials, port 6543 instead
# of 5432 on Supabase). Auto-derived from DATABASE_URL if unset — only set
# this if your transaction-mode connection string differs from that.
# DATABASE_POOL_URL=postgresql://user:password@host:port/dbname
# Comma-separated list of frontend origins allowed to call this API.
# Defaults to the Vite dev server if unset.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
SUPABASE_URL=
SUPABASE_KEY=
# Required for the assignment-fit AI advisor -- without it, is_configured()
# returns false and the endpoint responds "AI advisor is not configured."
GEMINI_API_KEY=
DAILY_API_KEY=